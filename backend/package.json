{
  "name": "backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup && printf '{\"type\":\"module\"}' > dist/package.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-ssm": "^3.600.0",
    "@aws-sdk/client-translate": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "hono": "^4.5.0"
  },
  "devDependencies": {
    "@hono/node-server": "^1.12.0",
    "@types/node": "^20.14.0",
    "tsup": "^8.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
