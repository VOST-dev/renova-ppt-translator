{
  "name": "translator-v2",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green 'pnpm run dev:frontend' 'pnpm run dev:backend'",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "build:frontend": "pnpm --filter frontend build",
    "build:backend": "pnpm --filter backend build",
    "build:infra": "pnpm --filter infra build",
    "deploy": "pnpm build:backend && pnpm --filter infra deploy",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "concurrently": "^9.2.1",
    "lefthook": "^2.1.3",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
